#!/usr/bin/env bash
# hooks/pre-commit — PZ Import Processor golden-constants guard
# =============================================================
# Install: make install-hooks   (copies this file to .git/hooks/pre-commit)
#
# Rule: if golden_constants.py is staged, the full regression suite must pass
# before the commit is allowed.
#
# Rationale: golden_constants.py is a ledger. Committing a change to it without
# passing tests means the constants were edited to silence a failure rather than
# to reflect a newly validated batch. This hook makes that physically impossible.

set -euo pipefail

GOLDEN="golden_constants.py"
TEST="test_pz_regression.py"

# Detect a working Python interpreter BY EXECUTION (not `command -v`).
# On Windows, `python3` may exist on PATH as a Microsoft Store alias
# shim that exits non-zero at runtime — so a PATH check is insufficient.
if python3 -c "" >/dev/null 2>&1; then
    PYTHON="python3"
elif python -c "" >/dev/null 2>&1; then
    PYTHON="python"
else
    echo "  ✗  No working Python interpreter found (tried python3, python)." >&2
    echo "     Install Python 3 or fix PATH before committing." >&2
    exit 1
fi

# Only activate when golden_constants.py is part of this commit
if git diff --cached --name-only | grep -q "^${GOLDEN}$"; then
    echo ""
    echo "  ── pre-commit: ${GOLDEN} is staged ──────────────────────────"
    echo "  Running regression suite before allowing commit..."
    echo "  (interpreter: ${PYTHON}, PYTHONUTF8=1)"
    echo ""

    # PYTHONUTF8=1 forces UTF-8 stdio so non-ASCII test output cannot
    # crash on a cp1252 (Windows) console — that would be a false block.
    if PYTHONUTF8=1 $PYTHON "$TEST"; then
        echo ""
        echo "  ✅ Tests passed — commit allowed."
        echo "  ────────────────────────────────────────────────────────"
        echo ""
    else
        echo ""
        echo "  ✗  Tests FAILED — commit blocked."
        echo ""
        echo "  golden_constants.py may only be committed when all tests pass."
        echo "  If you are updating reference values for a new validated batch:"
        echo "    1. Confirm tests fail on the new data first (expected)."
        echo "    2. Update golden_constants.py with values from the workbook."
        echo "    3. Re-run: python3 ${TEST}"
        echo "    4. Once green, commit with the required message format:"
        echo "         Update golden constants — shipment NNN–NNN"
        echo "         MRN: ..."
        echo "         NBP: ..."
        echo "         Validated against: ..."
        echo "  ────────────────────────────────────────────────────────"
        echo ""
        exit 1
    fi
fi

# ── Smoke gate: app-source-scoped, blocking ─────────────────────────────────
# Runs `pytest -m smoke` (alpha set) whenever any service/app/*.py is staged.
# Skips on docs/tooling/test-only commits to keep them fast. Reuses the same
# $PYTHON interpreter + PYTHONUTF8=1 detected above.
STAGED="$(git diff --cached --name-only)"
APP_PY="$(printf '%s\n' "$STAGED" | grep -E '^service/.*\.py$' | grep -vE '^service/tests/' || true)"

if [ -z "$APP_PY" ]; then
    echo "  smoke: skipped (no app source staged)"
    exit 0
fi

echo ""
echo "  ── pre-commit: app source staged — running smoke set ────────"
echo "  (interpreter: ${PYTHON}, PYTHONUTF8=1, -m smoke)"
echo ""

if ( cd service && PYTHONUTF8=1 $PYTHON -m pytest tests/ -m smoke -q -p no:cacheprovider ); then
    echo ""
    echo "  smoke: passed"
    echo "  ────────────────────────────────────────────────────────"
    echo ""
    exit 0
else
    echo ""
    echo "  ✗  SMOKE FAILED — commit blocked"
    echo "  ────────────────────────────────────────────────────────"
    echo ""
    exit 1
fi
