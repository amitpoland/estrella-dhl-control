+          </span>
+          <span style={{ color: 'var(--sidebar-text-muted)', fontSize: 11, marginLeft: 4 }}>
+            / PZ Correction
+          </span>
+          <div style={{ flex: 1 }} />
+          <a
+            href={`/dashboard/shipment-detail.html?id=${encodeURIComponent(URL_BATCH_ID)}`}
+            style={{ fontSize: 11, color: 'var(--sidebar-text-muted)', textDecoration: 'none' }}
+            data-testid="back-to-shipment-link"
+          >
+            ← Shipment
+          </a>
+        </header>
