+
+<script type="text/babel" data-presets="env,react">
+(function () {
+  'use strict';
+
+  // PZ Correction V2 — single-purpose standalone page.
+  // Single authority for the PZ Correction workflow. All rendering happens
+  // inside PzComponents.PZCorrectionV2Container. This file is a thin shell.
+
+  const _sp = new URLSearchParams(window.location.search);
+  const URL_BATCH_ID = (_sp.get('batch_id') || '').trim();
+
+  const { EstrellaMark, SessionBanner, EmptyState, Card } = window.EstrellaShared;
+  const { PZCorrectionV2Container } = window.PzComponents;
+
+  function PZCorrectionV2Root() {
+    const [sessionError, setSessionError] = React.useState(null);
+
+    if (!URL_BATCH_ID) {
+      return (
+        <div style={{ padding: 40, textAlign: 'center' }}>
